# Google Tag Manager (recommended: configure GA4 + other tags inside GTM)
# When set, the site loads gtm.js and pushes SPA page_view events to dataLayer.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 Measurement ID (use when not using GTM).
# If NEXT_PUBLIC_GTM_ID is set, only GTM loads; add GA4 inside GTM to avoid duplicate hits.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
