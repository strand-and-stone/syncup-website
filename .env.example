# Google Tag Manager (recommended: configure GA4 + other tags inside GTM)
# When set, the site loads gtm.js and pushes SPA page_view events to dataLayer.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 Measurement ID (use when not using GTM).
# If NEXT_PUBLIC_GTM_ID is set, only GTM loads; add GA4 inside GTM to avoid duplicate hits.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Resend Inbound: forward support@ → your inbox (optional) ---
# 1. Add syncupalarm.com in Resend → Domains → enable Receiving (MX/DNS as shown).
# 2. Create API key + Webhook (email.received) → https://YOUR_DOMAIN/api/webhooks/resend
# 3. RESEND_FORWARD_FROM must be an address on your verified sending domain in Resend.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
RESEND_FORWARD_TO=hello@strandandstonellc.com
RESEND_FORWARD_FROM=support@syncupalarm.com
# Comma-separated inbound addresses that trigger a forward (default: support@syncupalarm.com)
# RESEND_INBOUND_RECIPIENTS=support@syncupalarm.com
